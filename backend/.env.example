# Porta em que a API Express vai subir localmente
PORT=

# Ambiente de execução: "production" em produção, vazio/"development" localmente.
# Controla quais origens CORS são aceitas (ver FRONTEND_URL abaixo).
NODE_ENV=

# URL do frontend em produção, usada para restringir o CORS. Em
# desenvolvimento, http://localhost:5173 é sempre aceito além dessa URL.
FRONTEND_URL=

# Credenciais de conexão com o Azure SQL Database
DB_SERVER=
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_PORT=

# Opções de conexão exigidas/recomendadas pelo Azure SQL
DB_ENCRYPT=
DB_TRUST_SERVER_CERTIFICATE=

# Segredo usado para assinar/validar os tokens JWT (autenticação)
JWT_SECRET=

# Envio de relatório por e-mail via Brevo (https://api.brevo.com)
BREVO_API_KEY=
EMAIL_REMETENTE=
EMAIL_REMETENTE_NOME=
# lista separada por vírgula; cada endereço recebe o relatório
EMAIL_DESTINATARIOS=
